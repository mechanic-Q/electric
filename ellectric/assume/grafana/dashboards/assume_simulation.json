{
  "__inputs": [],
  "__requires": [],
  "title": "ASSUME 电力市场仿真",
  "description": "ASSUME 省间现货市场仿真结果 — 出清价格、机组调度量、联络线功率、智能体利润、新能源消纳率",
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "60s",
  "timepicker": {},
  "tags": ["assume", "electricity-market", "simulation", "china"],
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "出清价格时序",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "description": "逐小时省间现货出清价格 (元/MWh)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyCNY",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT $__time(time), price AS \"出清价格\" FROM market_results WHERE type='clearing' AND $__timeFilter(time) ORDER BY time",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "calcs": ["mean", "max", "min"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 2,
      "title": "各机组调度量",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "description": "各类型机组逐小时调度出力 (MW) — 堆叠面积图",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 80,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "coal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8B4513",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wind"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#87CEEB",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "solar"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FFD700",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "gas"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF6347",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT $__time(time), unit, SUM(dispatch_mw)::float AS \"调度量\" FROM dispatch_results WHERE $__timeFilter(time) GROUP BY time, unit ORDER BY time",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "calcs": ["mean", "last"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 3,
      "title": "省间联络线功率",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "description": "省间联络线交换功率 (MW) — 正值表示送出，负值表示受入",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT $__time(time), tie_line_mw AS \"联络线功率\" FROM tie_line_results WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "calcs": ["mean", "max", "min"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 4,
      "title": "各智能体累计利润",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "description": "各交易智能体累计利润 (元)",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyCNY",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT $__time(time), agent, cumulative_profit AS \"累计利润\" FROM agent_profits WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "calcs": ["mean", "last"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 5,
      "title": "新能源消纳率",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "description": "风电+光伏消纳率 (%) — 接近 100% 表示全额消纳",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT $__time(time), (1 - curtailment_rate) * 100 AS \"消纳率\" FROM renewable_curtailment WHERE $__timeFilter(time) ORDER BY time",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "calcs": ["mean", "last"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "11.0.0"
    }
  ]
}
