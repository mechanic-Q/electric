{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/karpathy-guidelines.md",
    ".planning/ROADMAP.md",
    ".planning/REQUIREMENTS.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp"],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "/mnt/e/Ellectric/.opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "/mnt/e/Ellectric/.opencode/get-shit-done/*": "allow"
    }
  }
}
